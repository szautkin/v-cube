{
  "name": "v-cube",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A Canadian Astronomy Data Centre (CADC) visualization tool — a browser-based FITS spectral-cube viewer with linked slice and volume modes, in a spacecraft-navigation cockpit.",
  "homepage": "https://github.com/szautkin/v-cube#readme",
  "bugs": "https://github.com/szautkin/v-cube/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szautkin/v-cube.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Serhii Zautkin <szautkin@gmail.com>",
  "keywords": [
    "fits",
    "astronomy",
    "spectral-cube",
    "datacube",
    "webgl",
    "three.js",
    "volume-rendering",
    "visualization",
    "wcs",
    "cadc"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/three": "^0.182.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.8"
  }
}
